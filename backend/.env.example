# ============================================
# IPO Tracker — backend environment variables
# ============================================
# Copy this file to `.env` and fill in your values:
#   cp .env.example .env
#
# Both the FastAPI server (main.py) and the data pipeline
# (python -m pipeline ...) read from this file.

# --- Supabase (required) --------------------
# SUPABASE_URL is the REST endpoint of your project.
# SUPABASE_KEY MUST be the service-role key — the anon key cannot
# write past Row Level Security, and the scraper needs insert/upsert.
# Find both at: Supabase Dashboard → Project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-service-role-key-here

# --- Optional: operator contact (polite-bot UA hint) ---
# Not currently added to the User-Agent (we rotate real browser UAs
# for anti-ban). Kept around for future use / audit logs.
OPERATOR_CONTACT=

# --- Optional tuning overrides --------------
# All pipeline rate-limit knobs live in backend/pipeline/config.py.
# Override by exporting env vars with the same UPPER_SNAKE names if
# you ever need to — the Settings dataclass is the source of truth.
